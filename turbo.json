{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "apps/compare/.next/**", "!apps/compare/.next/cache/**"],
      "env": ["DATABASE_URL", "CRON_SECRET", "NEXT_PUBLIC_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {}
  }
}
